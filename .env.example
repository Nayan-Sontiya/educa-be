# Mongo & JWT (existing)
MONGO_URI=
JWT_SECRET=
PORT=5000

# --- Cloudinary (for evidence file uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- OpenAI (for AI holistic analysis) ---
OPENAI_API_KEY=

# Public API base URL for uploaded files (no trailing slash). Used for news/gallery URLs in API responses.
# Production: https://api.utthanai.com
BASE_URL=http://localhost:5000

# --- Email ---
# Set to true after configuring Resend and/or SMTP below.
MAIL_ENABLED=false

# Optional: force transport. If unset, Resend is used when RESEND_API_KEY is set; otherwise SMTP.
# smtp — always Nodemailer (even if RESEND_API_KEY is set). Use for local Gmail when you also have a Resend key in env.
# resend — always Resend (needs RESEND_API_KEY).
# MAIL_TRANSPORT=smtp

# --- Resend (HTTPS; all sendMail() paths use this when key is set and MAIL_TRANSPORT is not smtp) ---
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="UtthanAI <onboarding@resend.dev>"

# --- SMTP (Nodemailer: used when no RESEND_API_KEY, or MAIL_TRANSPORT=smtp) ---
# SMTP server (examples below)
# Gmail: smtp.gmail.com — use an App Password, not your normal password
# Outlook: smtp-mail.outlook.com
# SendGrid: smtp.sendgrid.com (user "apikey", pass = your API key)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# If logs show ETIMEDOUT + command CONN (env looks correct): set on server — often fixes VPS IPv6 routing
# SMTP_FORCE_IPV4=true

SMTP_USER=your-email@gmail.com
SMTP_PASS=your_smtp_password_or_app_password

# From header (defaults to SMTP_USER if unset)
MAIL_FROM="UtthanAI <your-email@gmail.com>"

# Contact form: platform super admin inbox (defaults to sontiya.nayan@gmail.com if unset)
# CONTACT_ADMIN_EMAIL=

# Frontend URL for sign-in links and logo image in HTML emails (no trailing slash)
APP_PUBLIC_URL=http://localhost:3000

# Optional: public API base URL so emails can load the logo from this server (/brand/UtthanAI final Logo.PNG)
# API_PUBLIC_URL=http://localhost:5000

# Optional: override logo image URL in HTML emails (full URL to PNG)
# MAIL_BRAND_LOGO_URL=https://your-frontend.com/images/logo/UtthanAI final Logo.PNG

# --- Razorpay (school subscriptions) ---
# Dashboard → Account & Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
# Webhook: Dashboard → Webhooks → https://your-api/api/subscription/webhook
# Events: subscription.activated, subscription.charged, subscription.cancelled, payment.failed, payment.captured
WEBHOOK_SECRET=...
# Plans are auto-synced from Razorpay Dashboard (list plans API), matched by:
#   notes.plan = monthly|quarterly|yearly  OR  period+interval  OR  name containing those words.
# Razorpay Dashboard plan IDs (UtthanAI; also baked in as code defaults if unset):
RAZORPAY_PLAN_MONTHLY_ID=plan_SxENzCjfGpbGus
RAZORPAY_PLAN_QUARTERLY_ID=plan_SxENZseE1OcEEe
RAZORPAY_PLAN_YEARLY_ID=plan_SxEOmKaHzwrWZU
# RAZORPAY_PLAN_SYNC_TTL_MS=120000
# Billing cycles when end_at is not set (max 1200; auto-capped per plan)
# UPI checkout requires mandate expire_at <= 30 years — monthly ~360, yearly ~30.
# RAZORPAY_SUBSCRIPTION_TOTAL_COUNT=1200

# School web app base URL for Checkout success/cancel redirects (no trailing slash)
WEB_APP_URL=http://localhost:3000

# Parent app Play Store link in activation SMS (optional override)
# PARENT_APP_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.utthanai.app

# --- Firebase Phone Auth (OTP verification — replaces Fast2SMS for OTP) ---
# Firebase Console → Project settings → Service accounts → Generate new private key
# Paste project_id, client_email, private_key from the JSON (escape newlines in private key as \n)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional defaults (overridden by DB BillingSettings after first admin save)
# SUBSCRIPTION_PRICE_PER_STUDENT_YEAR_INR=300
# SUBSCRIPTION_GRACE_DAYS=3
# Default trial weeks if not set in Subscription Admin (BillingSettings.defaultTrialWeeks)
# SCHOOL_TRIAL_WEEKS=4
