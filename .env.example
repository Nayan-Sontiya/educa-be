# Mongo & JWT (existing)
MONGO_URI=
JWT_SECRET=
PORT=5000

# --- Cloudinary (for evidence file uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- OpenAI (for AI holistic analysis) ---
OPENAI_API_KEY=

# Optional: absolute base URL for uploaded files in API responses
# BASE_URL=http://localhost:5000

# --- Email ---
# Set to true after configuring SMTP below OR Resend (HTTPS) when your host blocks outbound 587/465
MAIL_ENABLED=false

# smtp (default) | resend — official `resend` SDK targets Node 20+; use Node 20+ image when using Resend
MAIL_TRANSPORT=smtp

# --- Resend (when MAIL_TRANSPORT=resend) ---
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="UtthanAI <onboarding@resend.dev>"

# --- SMTP (Nodemailer, default when MAIL_TRANSPORT unset or smtp) ---
# SMTP server (examples below)
# Gmail: smtp.gmail.com — use an App Password, not your normal password
# Outlook: smtp-mail.outlook.com
# SendGrid: smtp.sendgrid.com (user "apikey", pass = your API key)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# If logs show ETIMEDOUT + command CONN (env looks correct): set on server — often fixes VPS IPv6 routing
# SMTP_FORCE_IPV4=true

SMTP_USER=your-email@gmail.com
SMTP_PASS=your_smtp_password_or_app_password

# From header (defaults to SMTP_USER if unset)
MAIL_FROM="UtthanAI <your-email@gmail.com>"

# Contact form: platform super admin inbox (defaults to sontiya.nayan@gmail.com if unset)
# CONTACT_ADMIN_EMAIL=

# Frontend URL for sign-in links and logo image in HTML emails (no trailing slash)
APP_PUBLIC_URL=http://localhost:3000

# Optional: public API base URL so emails can load the logo from this server (/brand/UtthanAI final Logo.PNG)
# API_PUBLIC_URL=http://localhost:5000

# Optional: override logo image URL in HTML emails (full URL to PNG)
# MAIL_BRAND_LOGO_URL=https://your-frontend.com/images/logo/UtthanAI final Logo.PNG

# --- Stripe (school subscriptions, Checkout) ---
# server.js loads .env with override:true so values here replace empty STRIPE_* placeholders
# sometimes left in Windows User/System environment variables.
# Create a Product in Stripe Dashboard → copy Product ID (prod_...).
# Add active recurring prices in INR on that product (monthly / quarterly / yearly or custom intervals).
# Each price unit_amount = charge per active student for that billing period (app sends quantity = student count).
STRIPE_SECRET_KEY=sk_test_...
# Local: run `stripe listen --forward-to localhost:5000/api/subscription/webhook` and paste the printed whsec_... here.
# Production: Dashboard → Webhooks → endpoint URL https://your-api/api/subscription/webhook (same signing secret as configured there).
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRODUCT_ID=prod_...

# Optional — use ONE of these approaches for Checkout payment methods:
#
# A) Payment Method Configuration ID (pmc_...) from Dashboard → Settings → Payment methods.
#    This app uses Checkout in **subscription** mode. Your configuration must enable UPI (and others) for
#    **subscriptions / recurring**, not only one-time payments — expand each method in the Dashboard.
#    If you still only see card, try leaving this unset so Stripe uses the account default configuration.
#    @see https://docs.stripe.com/payments/payment-method-configurations
# STRIPE_PAYMENT_METHOD_CONFIGURATION_ID=pmc_...
#
# B) Explicit payment_method_types (comma-separated). Many accounts return API errors for "upi" even when
#    UPI appears enabled in Settings — that usually means UPI is not available for your account + subscription flow.
# STRIPE_CHECKOUT_PAYMENT_METHOD_TYPES=card
#
# If A/B/C are all unset, Checkout uses automatic_payment_methods.enabled=true (Stripe picks from Dashboard).
# Set false if your API returns an error for this parameter on subscription Checkout.
# STRIPE_CHECKOUT_AUTOMATIC_PAYMENT_METHODS=false

# School web app base URL for Checkout success/cancel redirects (no trailing slash)
WEB_APP_URL=http://localhost:3000

# Optional defaults (overridden by DB BillingSettings after first admin save)
# SUBSCRIPTION_PRICE_PER_STUDENT_YEAR_INR=300
# SUBSCRIPTION_GRACE_DAYS=3
